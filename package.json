{
  "name": "gacha-agent-core",
  "version": "0.1.0",
  "description": "AI agent for Pokemon card disambiguation, deal detection, and marketplace monitoring",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "tsx src/cli.ts",
