# Required — PokemonPriceTracker API (card resolution)
POKEMON_PRICE_TRACKER_API_KEY=your_pokemonpricetracker_api_key
POKEMON_PRICE_TRACKER_URL=https://www.pokemonpricetracker.com

# Required — PriceCharting API (FMV pricing)
PRICECHARTING_API_KEY=your_pricecharting_api_key

# Required for scan/run — eBay Developer API
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_SANDBOX=false

# Optional — Pokemon TCG API (TCGPlayer ungraded prices)
POKEMON_TCG_API_KEY=your_pokemon_tcg_api_key

# Required for run — Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Required — Google Gemini API (AI chat agent)
GEMINI_API_KEY=your_gemini_api_key

# Optional — Server
GACHA_ADMIN_KEY=your_admin_key
DEVELOPER_CHAT_ID=your_developer_telegram_chat_id
CORS_ORIGIN=*
PORT=3577
HOST=0.0.0.0
SKILL_DIR=../gacha-openclaw-skill

# Optional — General
DATA_PATH=./data
USER_ID=default
SCAN_INTERVAL_MS=900000
MIN_DEAL_SCORE=60
